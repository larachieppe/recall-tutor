# Copy this file to .env.local and fill in your key.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for generation + grading.
# Default is claude-opus-4-8 (highest quality). For lower cost you can use
# claude-sonnet-5 or claude-haiku-4-5.
# ANTHROPIC_MODEL=claude-opus-4-8
