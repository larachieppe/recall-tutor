# Copy this file to .env.local and fill in your key.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: YouTube transcripts. Paste a YouTube link as a source and the app
# pulls its transcript to learn from — requires a managed transcript API key
# (free tier at https://supadata.ai). Without it, YouTube links show a message.
# SUPADATA_API_KEY=...

# Optional: audio/video transcription. Upload an audio/video file or paste a
# direct media URL (.mp4/.mp3/…) and the app transcribes the speech to learn
# from. Requires a speech-to-text key (Deepgram: https://deepgram.com).
# Without it, media sources show a message.
# DEEPGRAM_API_KEY=...

# Optional: app-wide ceiling on paid AI calls per day (across all users), to
# limit cost if the public endpoints are abused. Default 300.
# IMPORTANT: also set a hard monthly spend limit on your Anthropic key in the
# console — that's the real financial backstop; this is defense-in-depth.
# DAILY_AI_LIMIT=300

# Optional: once GitHub sign-in is configured, generation requires sign-in —
# but anonymous users get this many free question sets per day first. Default 3.
# FREE_ANON_GENERATIONS=3

# --- Cost controls ---
# How much source text is sent per generation. This is the dominant input cost
# (it goes out on every generation), and the chunker samples across the WHOLE
# document, so a smaller budget still covers the full text. Default 30000.
# MAX_SOURCE_CHARS=30000
#
# TTL for the cached source-document prefix. Cache reads cost ~0.1x input;
# writes cost 1.25x at "5m" (default) and 2x at "1h". "5m" is the cheaper write
# but often expires while the learner is answering, so a follow-up round misses.
# "1h" survives a whole session but needs ~3 requests on the same source to pay
# off. Watch the [usage:*] cache_read logs and switch if reads stay at 0.
# ANTHROPIC_CACHE_TTL=5m

# Optional: override the model used for generation + grading.
# Default is claude-sonnet-5 (fast + capable). Use claude-opus-4-8 for the
# highest quality (slower), or claude-haiku-4-5 for the lowest latency.
# ANTHROPIC_MODEL=claude-sonnet-5
# Model for snappy, lower-stakes calls (the tutor chat). Defaults to Haiku.
# ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# --- Optional: cloud sync (Neon Postgres + Auth.js / GitHub) ---
# Leave ALL of these unset to run with local-only history (the default).
# Set all of them together to enable sign-in and cross-device sync.
#
# Neon pooled connection string (Neon dashboard → Connect):
# DATABASE_URL=postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
#
# Auth.js session secret — generate with: openssl rand -base64 33
# AUTH_SECRET=...
#
# GitHub OAuth app (github.com/settings/developers → New OAuth App).
# Homepage: your site URL; Authorization callback URL:
#   https://YOUR-SITE/api/auth/callback/github
# AUTH_GITHUB_ID=...
# AUTH_GITHUB_SECRET=...
#
# Turns on the Sign-in UI + sync in the browser (must be exactly "true"):
# NEXT_PUBLIC_AUTH_ENABLED=true
#
# On Render (behind a proxy) also set your public URL:
# AUTH_URL=https://YOUR-SITE

# --- Optional: closed-browser push reminders (Web Push / VAPID) ---
# Lets review reminders arrive even when the app tab is closed. Requires the
# cloud-sync block above (DATABASE_URL) so subscriptions can be stored and
# signed-in users' due counts can be read for personalized reminders.
#
# 1) Generate a key pair once:  npx web-push generate-vapid-keys
# 2) Set the private + public keys and a contact mailto: below.
# 3) Set NEXT_PUBLIC_VAPID_PUBLIC_KEY to the SAME public key (browser needs it).
# 4) Run `npm run db:push` to create the push_subscription table.
# Without these, the app falls back to in-tab reminders only.
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:you@example.com
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
#
# Shared secret protecting the send job (POST /api/push/send). A daily
# scheduler (cron-job.org, a GitHub Actions cron, etc.) calls that endpoint
# with header  Authorization: Bearer <CRON_SECRET>  to fan out reminders.
# CRON_SECRET=...
